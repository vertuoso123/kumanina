<!DOCTYPE html>
<html>
<head>
  <title>Watch</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style>
    body { margin:0; background:#000; color:#fff; font-family:Arial; text-align:center; }
    video { width:100%; max-height:70vh; }
    .title { padding:10px; font-size:18px; }
  </style>
</head>
<body>

<div class="title" id="title"></div>

<video controls autoplay id="player">
  <source id="source" src="" type="video/mp4">
</video>

<script>
const params = new URLSearchParams(window.location.search);
const vid = params.get("vid");

fetch('/posts.json')
.then(res => res.json())
.then(data => {
  let post = data[vid];
  document.getElementById('title').innerText = post.title;
  document.getElementById('source').src = post.url;
  document.getElementById('player').load();
});
</script>

</body>
</html>
